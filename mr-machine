# Mr. Machine Tool - Manual Mode
# An interactive troubleshooting guide for common Linux system issues.

# Function to display a separator
function separator {
    echo "-----------------------------------------------------"
}

# Function to pause for user input
function press_enter_to_continue {
    read -p "Press Enter to return to the previous menu..."
}

# Function for AI mode
function ai_mode {
    echo "Please explain your context for AI analysis."
    exit 0
}

# Function to execute a command and display its output
function run_command {
    echo "Executing: $1"
    echo "Command Output:"
    eval "$1" 2>&1 | sed 's/^/  /' # Indent output and redirect stderr to stdout
    echo "--- End of command output ---"
}

# Function for System & Boot Issues
function system_boot_menu {
    while true; do
        clear
        echo "Mr. Machine Tool - Manual Mode"
        separator
        echo "System & Boot Issues:"
        echo "1. System fails to boot due to corrupted GRUB configuration."
        echo "2. Kernel panic caused by incompatible drivers or missing modules."
        echo "3. Slow boot times due to unnecessary services running at startup."
        echo "4. Incorrect time settings due to misconfigured NTP or system clock."
        echo "5. System hanging during shutdown due to unresponsive processes."
        echo "0. Back to Main Menu"
        separator
        read -p "Enter your choice: " choice

        case $choice in
            1)
                clear
                echo "Problem: System fails to boot due to corrupted GRUB configuration."
                echo "This issue often requires manual intervention with device paths."
                echo "Please verify your boot drive (e.g., sda, sdb) before executing these commands."
                echo "To resolve, you might need to run (replace X with your boot drive):"
                echo "  sudo grub-install /dev/sdX"
                echo "  sudo update-grub"
                echo "If problem not solved, read this: https://wiki.ubuntu.com/Grub2/Troubleshooting"
                press_enter_to_continue
                ;;
            2)
                clear
                echo "Problem: Kernel panic caused by incompatible drivers or missing modules."
                echo "Attempting to run diagnostic commands..."
                run_command "sudo dmesg | grep -i \"panic\""
                echo "To update kernel and drivers (requires reboot): sudo apt update && sudo apt upgrade"
                echo "To recreate initramfs (replace $(uname -r) with current kernel version if different): sudo mkinitramfs -o /boot/initrd.img-$(uname -r) $(uname -r)"
                echo "If problem not solved, read this: https://www.kernel.org/doc/Documentation/admin-guide/bug-hunting.rst, https://wiki.archlinux.org/title/Kernel_panic"
                press_enter_to_continue
                ;;
            3)
                clear
                echo "Problem: Slow boot times due to unnecessary services running at startup."
                echo "Attempting to run diagnostic commands..."
                run_command "systemd-analyze blame | head -n 10" # Show top 10 slowest units
                echo "To disable a service, run: sudo systemctl disable <service_name> (replace <service_name> with one from the list above)"
                echo "If problem not solved, read this: https://ostechnix.com/speed-up-boot-time-in-linux-using-systemd-analyze/"
                press_enter_to_continue
                ;;
            4)
                clear
                echo "Problem: Incorrect time settings due to misconfigured NTP or system clock."
                echo "Attempting to run diagnostic commands..."
                run_command "timedatectl status"
                echo "To enable NTP sync: sudo timedatectl set-ntp true"
                echo "To set timezone (e.g., Asia/Kolkata, America/New_York): sudo timedatectl set-timezone Asia/Kolkata"
                echo "If problem not solved, read this: https://www.digitalocean.com/community/tutorials/how-to-set-up-time-synchronization-with-ntp-on-ubuntu-18-04"
                press_enter_to_continue
                ;;
            5)
                clear
                echo "Problem: System hanging during shutdown due to unresponsive processes."
                echo "Attempting to run diagnostic commands..."
                run_command "sudo journalctl -xb | grep -i \"shutdown\" | tail -n 20" # Show recent shutdown logs
                echo "As a last resort for an unresponsive process, you can kill it with: sudo pkill -9 <process_ID>"
                echo "If problem not solved, read this: https://unix.stackexchange.com/questions/27653/how-to-debug-a-hanging-shutdown"
                press_enter_to_continue
                ;;
            0)
                break
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Function for File System & Storage Problems
function file_system_menu {
    while true; do
        clear
        echo "Mr. Machine Tool - Manual Mode"
        separator
        echo "File System & Storage Problems:"
        echo "1. Disk space running out due to excessive log files or orphaned data."
        echo "2. File permissions preventing access to critical system files."
        echo "3. Corrupted file system requiring manual fsck repair."
        echo "4. Mounting issues with external drives or network shares."
        echo "5. RAID array failures leading to data loss or degraded performance."
        echo "0. Back to Main Menu"
        separator
        read -p "Enter your choice: " choice

        case $choice in
            1)
                clear
                echo "Problem: Disk space running out due to excessive log files or orphaned data."
                echo "Attempting to run diagnostic commands..."
                run_command "df -h"
                run_command "sudo du -sh /var/log/*" # Check log file sizes specifically
                echo "To free up space:"
                echo "  sudo apt autoremove"
                echo "  sudo journalctl --vacuum-size=50M (adjust size as needed, e.g., 1G)"
                echo "Consider using 'du -h --max-depth=1 /' to find large directories, but be aware it can take time."
                echo "If problem not solved, read this: https://www.howtogeek.com/118314/4-ways-to-free-up-disk-space-on-linux/"
                press_enter_to_continue
                ;;
            2)
                clear
                echo "Problem: File permissions preventing access to critical system files."
                echo "To diagnose, you need to specify the file path (e.g., /etc/fstab)."
                echo "Run: ls -l <file_path>"
                echo "To change permissions: sudo chmod <permissions> <file_path> (e.g., sudo chmod 644 /path/to/file)"
                echo "To change ownership: sudo chown <user>:<group> <file_path> (e.g., sudo chown root:root /path/to/file)"
                echo "If problem not solved, read this: https://www.redhat.com/sysadmin/linux-file-permissions-basics"
                press_enter_to_continue
                ;;
            3)
                clear
                echo "Problem: Corrupted file system requiring manual fsck repair."
                echo "This requires unmounting the partition and knowing its exact device path (e.g., /dev/sda1)."
                echo "DO NOT run fsck on a mounted partition as it can cause data loss."
                echo "Steps:"
                echo "  1. Boot from a live USB/CD."
                echo "  2. Identify the partition: lsblk"
                echo "  3. Unmount if necessary: sudo umount /dev/sdXN (replace XN with your partition)"
                echo "  4. Run fsck: sudo fsck -y /dev/sdXN"
                echo "If problem not solved, read this: https://www.cyberciti.biz/faq/unix-linux-check-repair-filesystem-fsck-command/"
                press_enter_to_continue
                ;;
            4)
                clear
                echo "Problem: Mounting issues with external drives or network shares."
                echo "Attempting to run diagnostic commands..."
                run_command "dmesg | tail -n 20" # Show recent kernel messages for mount errors
                echo "To try remounting all entries in /etc/fstab: sudo mount -a"
                echo "To reload systemd daemon configuration: sudo systemctl daemon-reload"
                echo "If problem not solved, read this: https://www.linuxshelltips.com/troubleshoot-mount-problems-linux/"
                press_enter_to_continue
                ;;
            5)
                clear
                echo "Problem: RAID array failures leading to data loss or degraded performance."
                echo "This requires knowing your RAID array (e.g., /dev/md0) and failed drive (e.g., /dev/sdY)."
                echo "Attempting to run diagnostic commands..."
                run_command "sudo mdadm --detail --scan" # List all detected RAID arrays
                echo "To check a specific array (replace X): sudo mdadm --detail /dev/mdX"
                echo "To add a new drive to a degraded array (replace X and Y): sudo mdadm --manage /dev/mdX --add /dev/sdY"
                echo "If problem not solved, read this: https://raid.wiki.kernel.org/index.php/RAID_Recovery"
                press_enter_to_continue
                ;;
            0)
                break
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Function for Networking & Connectivity Issues
function networking_menu {
    while true; do
        clear
        echo "Mr. Machine Tool - Manual Mode"
        separator
        echo "Networking & Connectivity Issues:"
        echo "1. No internet access due to misconfigured network interfaces."
        echo "2. DNS resolution failures causing slow or broken connections."
        echo "3. Firewall rules blocking legitimate traffic."
        echo "4. SSH connection failures due to incorrect key permissions."
        echo "5. VPN connectivity issues caused by missing dependencies."
        echo "0. Back to Main Menu"
        separator
        read -p "Enter your choice: " choice

        case $choice in
            1)
                clear
                echo "Problem: No internet access due to misconfigured network interfaces."
                echo "Attempting to run diagnostic commands..."
                run_command "ip addr show"
                run_command "ping -c 4 8.8.8.8" # Ping Google's DNS
                echo "To restart NetworkManager: sudo systemctl restart NetworkManager"
                echo "If problem not solved, read this: https://www.howtogeek.com/109041/how-to-troubleshoot-network-problems-on-linux/"
                press_enter_to_continue
                ;;
            2)
                clear
                echo "Problem: DNS resolution failures causing slow or broken connections."
                echo "Attempting to run diagnostic commands..."
                run_command "cat /etc/resolv.conf"
                run_command "dig google.com" # Requires 'dnsutils' package
                echo "To restart systemd-resolved (if used): sudo systemctl restart systemd-resolved"
                echo "If problem not solved, read this: https://www.redhat.com/sysadmin/dns-troubleshooting"
                press_enter_to_continue
                ;;
            3)
                clear
                echo "Problem: Firewall rules blocking legitimate traffic."
                echo "Attempting to run diagnostic commands..."
                run_command "sudo ufw status verbose" # If UFW is used
                run_command "sudo iptables -L -n -v" # Show raw iptables rules
                echo "If problem not solved, read this: https://ubuntu.com/server/docs/security-firewall-ufw, https://www.digitalocean.com/community/tutorials/how-to-list-and-delete-iptables-firewall-rules"
                press_enter_to_continue
                ;;
            4)
                clear
                echo "Problem: SSH connection failures due to incorrect key permissions."
                echo "Attempting to run diagnostic commands..."
                run_command "ls -l ~/.ssh/id_rsa"
                echo "Correct permissions for private key should be 600 (owner read/write only)."
                echo "To correct permissions: chmod 600 ~/.ssh/id_rsa"
                echo "If problem not solved, read this: https://www.ssh.com/academy/ssh/client-key-pair-permissions"
                press_enter_to_continue
                ;;
            5)
                clear
                echo "Problem: VPN connectivity issues caused by missing dependencies."
                echo "Attempting to run diagnostic commands..."
                run_command "sudo journalctl -u openvpn --since \"1 hour ago\" | tail -n 20" # Recent OpenVPN logs
                echo "If OpenVPN is not installed, install it: sudo apt install openvpn"
                echo "If problem not solved, read this: https://openvpn.net/community-resources/how-to-troubleshoot-common-openvpn-issues/"
                press_enter_to_continue
                ;;
            0)
                break
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Function for Performance & Resource Management
function performance_menu {
    while true; do
        clear
        echo "Mr. Machine Tool - Manual Mode"
        separator
        echo "Performance & Resource Management:"
        echo "1. High CPU usage due to rogue processes or misconfigured services."
        echo "2. Memory leaks causing system slowdowns."
        echo "3. Excessive swap usage leading to performance degradation."
        echo "4. Slow disk I/O affecting application responsiveness."
        echo "5. Background services consuming unnecessary resources."
        echo "0. Back to Main Menu"
        separator
        read -p "Enter your choice: " choice

        case $choice in
            1)
                clear
                echo "Problem: High CPU usage due to rogue processes or misconfigured services."
                echo "Attempting to run diagnostic commands..."
                run_command "top -bn1 | head -n 10" # Non-interactive top output
                echo "For interactive monitoring, use 'top' or 'htop' (sudo apt install htop)."
                echo "To kill a rogue process (use with caution!): sudo kill <PID>"
                echo "If problem not solved, read this: https://www.linux.com/training-certification/sysadmin-skills-101/how-to-diagnose-high-cpu-usage-on-linux/"
                press_enter_to_continue
                ;;
            2)
                clear
                echo "Problem: Memory leaks causing system slowdowns."
                echo "Attempting to run diagnostic commands..."
                run_command "free -h"
                run_command "ps aux --sort=-%mem | head -n 10" # Top 10 memory-consuming processes
                echo "To restart a service that might be leaking memory: sudo systemctl restart <service_name>"
                echo "If problem not solved, read this: https://www.redhat.com/sysadmin/linux-memory-leak-detection"
                press_enter_to_continue
                ;;
            3)
                clear
                echo "Problem: Excessive swap usage leading to performance degradation."
                echo "Attempting to run diagnostic commands..."
                run_command "swapon -s"
                run_command "cat /proc/sys/vm/swappiness" # Show current swappiness value
                echo "To lower swappiness (e.g., to 10): sudo sysctl vm.swappiness=10"
                echo "To make it permanent, add 'vm.swappiness=10' to /etc/sysctl.conf"
                echo "If problem not solved, read this: https://www.redhat.com/sysadmin/swap-space-linux"
                press_enter_to_continue
                ;;
            4)
                clear
                echo "Problem: Slow disk I/O affecting application responsiveness."
                echo "Attempting to run diagnostic commands..."
                run_command "iostat -x | head -n 10" # Requires sysstat package
                run_command "df -i" # Check inode usage
                echo "For interactive disk I/O monitoring, use 'iotop' (sudo apt install iotop)."
                echo "If problem not solved, read this: https://www.thegeekdiary.com/how-to-diagnose-disk-i-o-performance-issues-in-linux/"
                press_enter_to_continue
                ;;
            5)
                clear
                echo "Problem: Background services consuming unnecessary resources."
                echo "Attempting to run diagnostic commands..."
                run_command "systemctl list-units --type=service --state=running | head -n 10"
                echo "To stop a service: sudo systemctl stop <service_name>"
                echo "To disable a service from starting at boot: sudo systemctl disable <service_name>"
                echo "If problem not solved, read this: https://linuxconfig.org/how-to-manage-systemd-services-on-linux"
                press_enter_to_continue
                ;;
            0)
                break
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Function for Security & Access Control
function security_menu {
    while true; do
        clear
        echo "Mr. Machine Tool - Manual Mode"
        separator
        echo "Security & Access Control:"
        echo "1. Weak user passwords leading to unauthorized access."
        echo "2. SELinux or AppArmor blocking legitimate applications."
        echo "3. Misconfigured sudo permissions preventing administrative tasks."
        echo "4. Open ports exposing the system to potential attacks."
        echo "5. Unpatched vulnerabilities leading to security breaches."
        echo "0. Back to Main Menu"
        separator
        read -p "Enter your choice: " choice

        case $choice in
            1)
                clear
                echo "Problem: Weak user passwords leading to unauthorized access."
                echo "To change your own password: passwd"
                echo "To check password expiry for a specific user (replace <username>): sudo chage -l <username>"
                echo "If problem not solved, read this: https://www.ncsc.gov.uk/collection/passwords/passwords-guidance"
                press_enter_to_continue
                ;;
            2)
                clear
                echo "Problem: SELinux or AppArmor blocking legitimate applications."
                echo "Attempting to run diagnostic commands..."
                run_command "sudo sestatus" # For SELinux
                run_command "sudo aa-status" # For AppArmor
                echo "For SELinux, if in enforcing mode, check audit logs for denials: sudo ausearch -m AVC -ts today"
                echo "For AppArmor, check logs: sudo journalctl -u apparmor.service"
                echo "If problem not solved, read this: https://access.redhat.com/documentation/en-us/red_hat_enterprise_linux/7/html/selinux_users_and_administrators_guide/sect-security-enhanced_linux-troubleshooting-troubleshooting_steps.html, https://ubuntu.com/server/docs/security-apparmor"
                press_enter_to_continue
                ;;
            3)
                clear
                echo "Problem: Misconfigured sudo permissions preventing administrative tasks."
                echo "Attempting to run diagnostic commands..."
                run_command "sudo -l" # Lists your sudo privileges
                run_command "pkexec id" # Alternative for graphical auth, if pkexec is installed
                echo "To edit sudoers file (use 'visudo' for safety): sudo visudo"
                echo "If problem not solved, read this: https://www.digitalocean.com/community/tutorials/how-to-edit-the-sudoers-file-on-ubuntu-and-centos"
                press_enter_to_continue
                ;;
            4)
                clear
                echo "Problem: Open ports exposing the system to potential attacks."
                echo "Attempting to run diagnostic commands..."
                run_command "sudo ss -tulpn" # Lists TCP/UDP listening ports with process info
                run_command "sudo nmap localhost" # Requires nmap package
                echo "If problem not solved, read this: https://www.redhat.com/sysadmin/checking-open-ports-linux"
                press_enter_to_continue
                ;;
            5)
                clear
                echo "Problem: Unpatched vulnerabilities leading to security breaches."
                echo "Attempting to run diagnostic commands..."
                run_command "sudo apt update && sudo apt list --upgradable"
                run_command "uname -a" # Check kernel version for known vulnerabilities
                echo "To apply all pending updates: sudo apt upgrade"
                echo "If problem not solved, read this: https://ubuntu.com/security/cves, https://www.linux.com/training-certification/linux-security-basics-how-to-keep-your-system-safe/"
                press_enter_to_continue
                ;;
            0)
                break
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Function for Software & Package Management
function software_menu {
    while true; do
        clear
        echo "Mr. Machine Tool - Manual Mode"
        separator
        echo "Software & Package Management:"
        echo "1. Dependency conflicts when installing or updating packages."
        echo "2. Broken repositories preventing software updates."
        echo "3. Application crashes due to missing libraries."
        echo "4. Compatibility issues with proprietary drivers."
        echo "5. Kernel updates breaking existing configurations."
        echo "0. Back to Main Menu"
        separator
        read -p "Enter your choice: " choice

        case $choice in
            1)
                clear
                echo "Problem: Dependency conflicts when installing or updating packages."
                echo "Attempting to run diagnostic commands..."
                run_command "sudo apt update"
                echo "To fix broken packages: sudo apt --fix-broken install"
                echo "To clean package cache: sudo apt clean"
                echo "If problem not solved, read this: https://www.howtoforge.com/tutorial/how-to-fix-broken-packages-in-ubuntu/"
                press_enter_to_continue
                ;;
            2)
                clear
                echo "Problem: Broken repositories preventing software updates."
                echo "Attempting to run diagnostic commands..."
                run_command "sudo apt update" # Check for errors here
                run_command "cat /etc/apt/sources.list"
                run_command "grep -r ^deb /etc/apt/sources.list.d/" # Check additional repo files
                echo "To remove a problematic repository (replace <repository>): sudo add-apt-repository --remove <repository>"
                echo "If problem not solved, read this: https://linuxhint.com/fix-broken-apt-repositories-ubuntu/"
                press_enter_to_continue
                ;;
            3)
                clear
                echo "Problem: Application crashes due to missing libraries."
                echo "You need to specify the application binary path (e.g., /usr/bin/firefox)."
                echo "Run: ldd <application_binary>"
                echo "To install missing library (replace <missing_library>): sudo apt install <missing_library>"
                echo "If problem not solved, read this: https://www.baeldung.com/linux/ldd-command-missing-shared-libraries"
                press_enter_to_continue
                ;;
            4)
                clear
                echo "Problem: Compatibility issues with proprietary drivers."
                echo "Attempting to run diagnostic commands..."
                run_command "lspci -k | grep -EA3 'VGA|3D|Display|Kernel driver in use'" # Identify graphics card and driver
                run_command "sudo ubuntu-drivers list" # For Ubuntu-based systems
                echo "To autoinstall recommended drivers (for Ubuntu): sudo ubuntu-drivers autoinstall"
                echo "If problem not solved, read this: https://linuxconfig.org/how-to-install-nvidia-drivers-on-ubuntu-22-04-jammy-jellyfish-linux"
                press_enter_to_continue
                ;;
            5)
                clear
                echo "Problem: Kernel updates breaking existing configurations."
                echo "This is a sensitive operation. Proceed with extreme caution."
                echo "To list installed kernels: dpkg -l | grep linux-image"
                echo "To boot into an older kernel: Select it from the GRUB menu during startup."
                echo "To remove a specific kernel (replace version): sudo apt-get purge linux-image-unsigned-<version>"
                echo "After removing a kernel, update GRUB: sudo update-grub"
                echo "If problem not solved, read this: https://www.itzgeek.com/how-to/linux/how-to-uninstall-old-kernels-in-ubuntu-debian-linux.html"
                press_enter_to_continue
                ;;
            0)
                break
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Main Menu
function main_menu {
    while true; do
        clear
        echo "Welcome to Mr. Machine Tool system!"
        separator
        echo "Please select a mode:"
        echo "1. AI"
        echo "2. Manual"
        echo "0. Exit"
        separator
        read -p "Enter your choice: " mode_choice

        case $mode_choice in
            1)
                ai_mode
                ;;
            2)
                clear
                echo "Entering Mr. Machine Tool - Manual Mode."
                echo "NOTE: Some diagnostic commands will be executed automatically."
                echo "For commands requiring 'sudo', you may be prompted for your password."
                echo "Commands that require specific user input (e.g., device paths, service names)"
                echo "will be presented for manual execution with clear instructions."
                press_enter_to_continue

                while true; do
                    clear
                    echo "Mr. Machine Tool - Manual Mode"
                    separator
                    echo "Main Troubleshooting Menu:"
                    echo "1. System & Boot Issues"
                    echo "2. File System & Storage Problems"
                    echo "3. Networking & Connectivity Issues"
                    echo "4. Performance & Resource Management"
                    echo "5. Security & Access Control"
                    echo "6. Software & Package Management"
                    echo "0. Exit"
                    separator
                    read -p "Enter your choice: " category_choice

                    case $category_choice in
                        1) system_boot_menu ;;
                        2) file_system_menu ;;
                        3) networking_menu ;;
                        4) performance_menu ;;
                        5) security_menu ;;
                        6) software_menu ;;
                        0)
                            echo "Exiting Mr. Machine Tool. Goodbye!"
                            exit 0
                            ;;
                        *)
                            echo "Invalid choice. Please try again."
                            press_enter_to_continue
                            ;;
                    esac
                done
                ;;
            0)
                echo "Exiting Mr. Machine Tool. Goodbye!"
                exit 0
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Start the script
main_menu

