# Function for Performance & Resource Management
function performance_menu {
    while true; do
        clear
        echo "Mr. Machine Tool - Manual Mode"
        separator
        echo "Performance & Resource Management:"
        echo "1. High CPU usage due to rogue processes or misconfigured services."
        echo "2. Memory leaks causing system slowdowns."
        echo "3. Excessive swap usage leading to performance degradation."
        echo "4. Slow disk I/O affecting application responsiveness."
        echo "5. Background services consuming unnecessary resources."
        echo "0. Back to Main Menu"
        separator
        read -p "Enter your choice: " choice

        case $choice in
            1)
                clear
                echo "Problem: High CPU usage due to rogue processes or misconfigured services."
                echo "Recommended Commands:"
                echo "  top"
                echo "  htop (install if not available: sudo apt install htop)"
                echo "  sudo kill <PID> (replace <PID> with the Process ID of the rogue process)"
                echo "If problem not solved, read this: [Diagnosing high CPU usage]"
                press_enter_to_continue
                ;;
            2)
                clear
                echo "Problem: Memory leaks causing system slowdowns."
                echo "Recommended Commands:"
                echo "  free -h"
                echo "  ps aux --sort=-%mem"
                echo "  sudo systemctl restart <service_name> (replace <service_name> with the service exhibiting the leak)"
                echo "If problem not solved, read this: [Identifying memory leaks]"
                press_enter_to_continue
                ;;
            3)
                clear
                echo "Problem: Excessive swap usage leading to performance degradation."
                echo "Recommended Commands:"
                echo "  swapon -s"
                echo "  sudo sysctl vm.swappiness=10 (lowers swappiness, default is 60)"
                echo "If problem not solved, read this: [Optimizing swap usage]"
                press_enter_to_continue
                ;;
            4)
                clear
                echo "Problem: Slow disk I/O affecting application responsiveness."
                echo "Recommended Commands:"
                echo "  iostat -x (install if not available: sudo apt install sysstat)"
                echo "  iotop (install if not available: sudo apt install iotop)"
                echo "If problem not solved, read this: [Disk I/O performance tuning]"
                press_enter_to_continue
                ;;
            5)
                clear
                echo "Problem: Background services consuming unnecessary resources."
                echo "Recommended Commands:"
                echo "  systemctl list-units --type=service --state=running"
                echo "  sudo systemctl stop <service_name>"
                echo "If problem not solved, read this: [Managing systemd services]"
                press_enter_to_continue
                ;;
            0)
                break
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Function for Security & Access Control
function security_menu {
    while true; do
        clear
        echo "Mr. Machine Tool - Manual Mode"
        separator
        echo "Security & Access Control:"
        echo "1. Weak user passwords leading to unauthorized access."
        echo "2. SELinux or AppArmor blocking legitimate applications."
        echo "3. Misconfigured sudo permissions preventing administrative tasks."
        echo "4. Open ports exposing the system to potential attacks."
        echo "5. Unpatched vulnerabilities leading to security breaches."
        echo "0. Back to Main Menu"
        separator
        read -p "Enter your choice: " choice

        case $choice in
            1)
                clear
                echo "Problem: Weak user passwords leading to unauthorized access."
                echo "Recommended Commands:"
                echo "  passwd (to change current user's password)"
                echo "  sudo chage -l <username> (to check password expiry for a user)"
                echo "If problem not solved, read this: [Strong password policies]"
                press_enter_to_continue
                ;;
            2)
                clear
                echo "Problem: SELinux or AppArmor blocking legitimate applications."
                echo "Recommended Commands:"
                echo "  sudo sestatus (for SELinux)"
                echo "  sudo audit2allow -a (for SELinux, to generate allow rules)"
                echo "  sudo aa-status (for AppArmor)"
                echo "If problem not solved, read this: [SELinux troubleshooting], [AppArmor policy creation]"
                press_enter_to_continue
                ;;
            3)
                clear
                echo "Problem: Misconfigured sudo permissions preventing administrative tasks."
                echo "Recommended Commands:"
                echo "  sudo -l (to list your sudo privileges)"
                echo "  pkexec id (alternative to sudo for graphical applications)"
                echo "If problem not solved, read this: [Understanding sudoers file]"
                press_enter_to_continue
                ;;
            4)
                clear
                echo "Problem: Open ports exposing the system to potential attacks."
                echo "Recommended Commands:"
                echo "  sudo ss -tulpn (lists TCP/UDP listening ports with process info)"
                echo "  sudo nmap localhost (install if not available: sudo apt install nmap)"
                echo "If problem not solved, read this: [Securing open ports]"
                press_enter_to_continue
                ;;
            5)
                clear
                echo "Problem: Unpatched vulnerabilities leading to security breaches."
                echo "Recommended Commands:"
                echo "  sudo apt update && sudo apt upgrade"
                echo "  uname -a (to check kernel version and patch level)"
                echo "If problem not solved, read this: [Vulnerability scanning tools]"
                press_enter_to_continue
                ;;
            0)
                break
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Function for Software & Package Management
function software_menu {
    while true; do
        clear
        echo "Mr. Machine Tool - Manual Mode"
        separator
        echo "Software & Package Management:"
        echo "1. Dependency conflicts when installing or updating packages."
        echo "2. Broken repositories preventing software updates."
        echo "3. Application crashes due to missing libraries."
        echo "4. Compatibility issues with proprietary drivers."
        echo "5. Kernel updates breaking existing configurations."
        echo "0. Back to Main Menu"
        separator
        read -p "Enter your choice: " choice

        case $choice in
            1)
                clear
                echo "Problem: Dependency conflicts when installing or updating packages."
                echo "Recommended Commands:"
                echo "  sudo apt --fix-broken install"
                echo "  sudo apt clean"
                echo "  sudo apt update"
                echo "If problem not solved, read this: [Resolving dependency issues]"
                press_enter_to_continue
                ;;
            2)
                clear
                echo "Problem: Broken repositories preventing software updates."
                echo "Recommended Commands:"
                echo "  sudo apt update (check for errors)"
                echo "  cat /etc/apt/sources.list"
                echo "  sudo add-apt-repository --remove <repository> (replace <repository> with the problematic one)"
                echo "If problem not solved, read this: [Fixing broken APT repositories]"
                press_enter_to_continue
                ;;
            3)
                clear
                echo "Problem: Application crashes due to missing libraries."
                echo "Recommended Commands:"
                echo "  ldd <application_binary> (replace <application_binary> with the path to the executable)"
                echo "  sudo apt install <missing_library>"
                echo "If problem not solved, read this: [Troubleshooting missing libraries]"
                press_enter_to_continue
                ;;
            4)
                clear
                echo "Problem: Compatibility issues with proprietary drivers."
                echo "Recommended Commands:"
                echo "  lspci -k (to identify hardware and current kernel driver)"
                echo "  sudo ubuntu-drivers autoinstall (for Ubuntu-based systems)"
                echo "If problem not solved, read this: [Installing proprietary drivers]"
                press_enter_to_continue
                ;;
            5)
                clear
                echo "Problem: Kernel updates breaking existing configurations."
                echo "Recommended Commands:"
                echo "  sudo apt-get purge linux-image-unsigned-$(uname -r) (uninstall current kernel, use with caution!)"
                echo "  sudo update-grub (after uninstalling a kernel)"
                echo "If problem not solved, read this: [Rolling back kernel updates]"
                press_enter_to_continue
                ;;
            0)
                break
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Main Menu
function main_menu {
    while true; do
        clear
        echo "Welcome to Mr. Machine Tool system!"
        separator
        echo "Please select a mode:"
        echo "1. AI"
        echo "2. Manual"
        echo "0. Exit"
        separator
        read -p "Enter your choice: " mode_choice

        case $mode_choice in
            1)
                ai_mode
                ;;
            2)
                while true; do
                    clear
                    echo "Mr. Machine Tool - Manual Mode"
                    separator
                    echo "Main Troubleshooting Menu:"
                    echo "1. System & Boot Issues"
                    echo "2. File System & Storage Problems"
                    echo "3. Networking & Connectivity Issues"
                    echo "4. Performance & Resource Management"
                    echo "5. Security & Access Control"
                    echo "6. Software & Package Management"
                    echo "0. Exit"
                    separator
                    read -p "Enter your choice: " category_choice

                    case $category_choice in
                        1) system_boot_menu ;;
                        2) file_system_menu ;;
                        3) networking_menu ;;
                        4) performance_menu ;;
                        5) security_menu ;;
                        6) software_menu ;;
                        0)
                            echo "Exiting Mr. Machine Tool. Goodbye!"
                            exit 0
                            ;;
                        *)
                            echo "Invalid choice. Please try again."
                            press_enter_to_continue
                            ;;
                    esac
                done
                ;;
            0)
                echo "Exiting Mr. Machine Tool. Goodbye!"
                exit 0
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Start the script
main_menu
