# Mr. Machine Tool - Manual Mode
# An interactive troubleshooting guide for common Linux system issues.

# Function to display a separator
function separator {
    echo "-----------------------------------------------------"
}

# Function to pause for user input
function press_enter_to_continue {
    read -p "Press Enter to return to the previous menu..."
}

# Function for AI mode
function ai_mode {
    echo "Please explain your context for AI analysis."
    exit 0
}

# Function for System & Boot Issues
function system_boot_menu {
    while true; do
        clear
        echo "Mr. Machine Tool - Manual Mode"
        separator
        echo "System & Boot Issues:"
        echo "1. System fails to boot due to corrupted GRUB configuration."
        echo "2. Kernel panic caused by incompatible drivers or missing modules."
        echo "3. Slow boot times due to unnecessary services running at startup."
        echo "4. Incorrect time settings due to misconfigured NTP or system clock."
        echo "5. System hanging during shutdown due to unresponsive processes."
        echo "0. Back to Main Menu"
        separator
        read -p "Enter your choice: " choice

        case $choice in
            1)
                clear
                echo "Problem: System fails to boot due to corrupted GRUB configuration."
                echo "Recommended Commands:"
                echo "  sudo grub-install /dev/sdX (replace X with your boot drive, e.g., sda)"
                echo "  sudo update-grub"
                echo "If problem not solved, read this: [GRUB troubleshooting guide]"
                press_enter_to_continue
                ;;
            2)
                clear
                echo "Problem: Kernel panic caused by incompatible drivers or missing modules."
                echo "Recommended Commands:"
                echo "  sudo dmesg | grep -i \"panic\""
                echo "  sudo apt update && sudo apt upgrade (to update kernel and drivers)"
                echo "  sudo mkinitramfs -o /boot/initrd.img-$(uname -r) $(uname -r)"
                echo "If problem not solved, read this: [Kernel panic diagnostic tips], [Driver installation guide]"
                press_enter_to_continue
                ;;
            3)
                clear
                echo "Problem: Slow boot times due to unnecessary services running at startup."
                echo "Recommended Commands:"
                echo "  systemd-analyze blame"
                echo "  sudo systemctl disable <service_name> (replace <service_name> with the service you want to disable)"
                echo "If problem not solved, read this: [Optimizing boot times]"
                press_enter_to_continue
                ;;
            4)
                clear
                echo "Problem: Incorrect time settings due to misconfigured NTP or system clock."
                echo "Recommended Commands:"
                echo "  timedatectl status"
                echo "  sudo timedatectl set-ntp true"
                echo "  sudo timedatectl set-timezone Asia/Kolkata (or appropriate timezone, e.g., America/New_York)"
                echo "If problem not solved, read this: [NTP configuration guide]"
                press_enter_to_continue
                ;;
            5)
                clear
                echo "Problem: System hanging during shutdown due to unresponsive processes."
                echo "Recommended Commands:"
                echo "  sudo journalctl -xb | grep -i \"shutdown\""
                echo "  sudo pkill -9 <process_ID> (as a last resort, replace <process_ID>)"
                echo "If problem not solved, read this: [Troubleshooting shutdown issues]"
                press_enter_to_continue
                ;;
            0)
                break
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

# Function for File System & Storage Problems
function file_system_menu {
    while true; do
        clear
        echo "Mr. Machine Tool - Manual Mode"
        separator
        echo "File System & Storage Problems:"
        echo "1. Disk space running out due to excessive log files or orphaned data."
        echo "2. File permissions preventing access to critical system files."
        echo "3. Corrupted file system requiring manual fsck repair."
        echo "4. Mounting issues with external drives or network shares."
        echo "5. RAID array failures leading to data loss or degraded performance."
        echo "0. Back to Main Menu"
        separator
        read -p "Enter your choice: " choice

        case $choice in
            1)
                clear
                echo "Problem: Disk space running out due to excessive log files or orphaned data."
                echo "Recommended Commands:"
                echo "  df -h"
                echo "  du -sh /* (use with caution, can take a while)"
                echo "  sudo apt autoremove"
                echo "  sudo journalctl --vacuum-size=50M (adjust size as needed)"
                echo "If problem not solved, read this: [Freeing up disk space]"
                press_enter_to_continue
                ;;
            2)
                clear
                echo "Problem: File permissions preventing access to critical system files."
                echo "Recommended Commands:"
                echo "  ls -l <file_path> (replace <file_path>)"
                echo "  sudo chmod <permissions> <file_path> (e.g., sudo chmod 644 /path/to/file)"
                echo "  sudo chown <user>:<group> <file_path> (e.g., sudo chown root:root /path/to/file)"
                echo "If problem not solved, read this: [Understanding Linux file permissions]"
                press_enter_to_continue
                ;;
            3)
                clear
                echo "Problem: Corrupted file system requiring manual fsck repair."
                echo "Recommended Commands:"
                echo "  sudo umount /dev/sdXN (replace XN with your partition, e.g., sda1)"
                echo "  sudo fsck -y /dev/sdXN (replace XN with your partition)"
                echo "If problem not solved, read this: [fsck usage and recovery]"
                press_enter_to_continue
                ;;
            4)
                clear
                echo "Problem: Mounting issues with external drives or network shares."
                echo "Recommended Commands:"
                echo "  dmesg | tail"
                echo "  sudo mount -a"
                echo "  sudo systemctl daemon-reload"
                echo "If problem not solved, read this: [Troubleshooting mount points]"
                press_enter_to_continue
                ;;
            5)
                clear
                echo "Problem: RAID array failures leading to data loss or degraded performance."
                echo "Recommended Commands:"
                echo "  sudo mdadm --detail /dev/mdX (replace X with your RAID array, e.g., md0)"
                echo "  sudo mdadm --manage /dev/mdX --add /dev/sdY (replace X and Y with your array and failed drive)"
                echo "If problem not solved, read this: [RAID recovery procedures]"
                press_enter_to_continue
                ;;
            0)
                break
                ;;
            *)
                echo "Invalid choice. Please try again."
                press_enter_to_continue
                ;;
        esac
    done
}

